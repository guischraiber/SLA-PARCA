# Copie estas variáveis para o painel do Vercel: Settings > Environment Variables

# Senha simples para acessar a visão interna (?admin=SENHA) e autorizar importações
ADMIN_TOKEN=defina-uma-senha-forte-aqui

# --- Necessárias para o botão "Importar Dados" salvar os CSVs no repositório ---

# Personal Access Token do GitHub com permissão de escrita (Contents: Read and write)
# Gere em: GitHub > Settings > Developer settings > Fine-grained tokens > Generate new token
# Escopo: só o repositório score-parca, permissão "Contents" = Read and write
GITHUB_TOKEN=github_pat_XXXXXXXXXXXX

# Seu usuário/organização do GitHub
GITHUB_OWNER=seu-usuario

# Nome do repositório
GITHUB_REPO=score-parca

# Opcional — branch onde salvar (padrão: main)
GITHUB_BRANCH=main
